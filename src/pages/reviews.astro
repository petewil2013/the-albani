---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Reviews" description="Guest impressions of Villa Sancti Albani and The Albani.">
	<div class="content content--narrow">
		<h1>Reviews</h1>
		<p class="lede">
			We are collecting first stays for summer. If you have already visited for a work weekend or a soft opening, we would be grateful for a few sentences we can
			quote here with your permission.
		</p>

		<div class="card" style="margin: var(--space-lg) 0;">
			<p style="margin: 0; font-style: italic;">
				&ldquo;Placeholder: add a short guest quote, first name, and season once you have real stays to reference.&rdquo;
			</p>
		</div>

		<h2>Leave feedback</h2>
		<p>
			Email <a href="mailto:stay@thealbani.com">stay@thealbani.com</a> with the subject line <strong>Guest review</strong>, or paste the same address into your
			own Google Form if you prefer structured submissions later.
		</p>
	</div>
</BaseLayout>
