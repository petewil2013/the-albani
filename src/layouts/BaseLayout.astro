---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteBase } from "../utils/site-base";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	heroImage?: string;
}

const { title, description = "The Albani — Villa Sancti Albani. A refined woodland estate between Bangor and Augusta, Maine.", heroImage } = Astro.props;
const fullTitle = title === "The Albani" ? title : `${title} · The Albani`;
const base = siteBase();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<meta name="permissions-policy" content="camera=(), microphone=(), geolocation=()" />
		<meta
			http-equiv="Content-Security-Policy"
			content="default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests; script-src 'self' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://*.tile.openstreetmap.org https://fonts.googleapis.com https://fonts.gstatic.com; form-action 'self' https://buy.stripe.com https://checkout.stripe.com https://pay.stripe.com https://payments.stripe.com https://billing.stripe.com https://invoice.stripe.com https://donate.stripe.com https://stripe.com https://js.stripe.com https://hooks.stripe.com https://account.venmo.com;"
		/>
		<meta name="description" content={description} />
		<link rel="icon" type="image/png" href={`${base}logo.png`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{fullTitle}</title>
		<slot name="head" />
	</head>
	<body>
		<Header />
		<slot name="hero" />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
