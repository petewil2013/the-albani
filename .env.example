# Copy to .env and fill in. PUBLIC_* vars are embedded at build time.
# Never put secrets in PUBLIC_* — they ship in static HTML.

# Stripe Payment Link: must be https:// on a Stripe host (buy.stripe.com, checkout.stripe.com, etc.).
# Invalid values are ignored at build time (button stays disabled).
PUBLIC_STRIPE_PAYMENT_LINK=

# Venmo public username (2–50 chars: letters, digits, underscore, hyphen). No @.
# Invalid values are ignored at build time.
PUBLIC_VENMO_USERNAME=
